# .env
PORT=5000
JWT_SECRET=sua_super_secreta_chave_jwt_aqui 
OCI_TENANCY_OCID=ocid1.tenancy.oc1..your_tenancy_ocid
OCI_USER_OCID=ocid1.user.oc1..your_user_ocid
OCI_FINGERPRINT=your_api_key_fingerprint
OCI_PRIVATE_KEY_PATH=./oci_api_key.pem # Path to your OCI private key file (ex: C:\Users\SeuUsuario\.oci\oci_api_key.pem)
OCI_REGION=your_oci_region # e.g., sa-saopaulo-1